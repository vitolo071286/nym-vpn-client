{
  "name": "nym-vpn-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "authors": [
    "pierre <dommerc.pierre@gmail.com>",
    "zane <zanecschepke@gmail.com>",
    "nym"
  ],
  "description": "Nym VPN Desktop Client",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "dev:app": "tauri dev",
    "dev:browser": "vite --mode dev-browser",
    "check": "run-s lint tscheck fmt",
    "build": "tsc && vite build",
    "build:app": "npm run tauri build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "fmt": "prettier --write --ignore-unknown \"**/*\"",
    "fmt:check": "prettier --check --ignore-unknown \"**/*\"",
    "tscheck": "tsc --noEmit",
    "tauri": "tauri",
    "gen:licenses": "run-p --aggregate-output gen:licenses:rust gen:licenses:js",
    "gen:licenses:js": "npx --yes license-checker-rseidelsohn@4.3.0 --production --json > public/licenses-js.json",
    "gen:licenses:rust": "cargo license -j --avoid-dev-deps --avoid-build-deps --manifest-path src-tauri/Cargo.toml > public/licenses-rust.json"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-toast": "^1.2.6",
    "@sentry/react": "^9.2.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-autostart": "^2.2.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.2.5",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@tauri-apps/plugin-window-state": "^2.0.0",
    "clsx": "^2.0.0",
    "dayjs": "^1.11.10",
    "i18next": "^24.0.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "lodash-es": "^4.17.21",
    "motion": "^12.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-router": "^7.5.2",
    "react-virtualized-auto-sizer": "^1.0.23",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@tailwindcss/vite": "^4.0.5",
    "@tauri-apps/cli": "^2.3.0",
    "@types/eslint__js": "^8.42.3",
    "@types/lodash-es": "^4.17.0",
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.0.1",
    "vite": "^6.3.6",
    "vite-plugin-svgr": "^4.2.0"
  }
}
