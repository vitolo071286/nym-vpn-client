    "modeSelectionInfo.anonymousDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disfruta de la máxima privacidad con enrutamiento de tu conexión a través de 5 servidores por la mixnet. Perfecto para gestionar de forma segura los pagos, correos electrónicos y mensajes."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bénéficiez d'une confidentialité maximale via les 5 passerelles du mixnet. Parfait transmettre vos instructions de paiement, vos emails et vos messages."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5つのサーバーを通じてMixnet経由で接続をルーティングすることで、最高レベルのプライバシーを実現します。支払い、メール、メッセージの安全な取り扱いに最適です。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enjoy maximum-level privacy by routing your connection through 5 servers via mixnet. Perfect for securely handling payments, emails, and messages."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aproveite a privacidade de nível máximo ao rotear sua conexão por meio de 5 servidores via mixnet. Perfeito para lidar com segurança com pagamentos, emails e mensagens."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наслаждайтесь максимальной конфиденциальностью, направляя ваше соединение через 5 серверов с помощью микснета. Идеально для безопасной обработки платежей, электронной почты и сообщений."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bağlantınızı mixnet üzerinden 5 sunucuya yönlendirerek en yüksek düzeyde gizliliğin tadını çıkarın. Ödemeler, e-postalar ve mesajlar için güvenli bir şekilde işlem yapmaya mükemmel bir çözümdür."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Насолоджуйтесь максимальним рівнем конфіденційності завдяки маршрутизації вашого з'єднання за допомогою 5 серверів mixnet. Ідеально підходить для безпечної обробки платежів, електронних листів та повідомлень."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tận hưởng quyền riêng tư ở mức tối đa bằng cách định tuyến kết nối của bạn qua 5 máy chủ thông qua mixnet. Hoàn hảo để xử lý thanh toán, email và tin nhắn một cách an toàn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过混合网络将连接路由到5台服务器，您将享受最高级别的隐私保障。这是安全处理付款、邮件和消息的最佳选择。"
          }
        }
      }
    },
