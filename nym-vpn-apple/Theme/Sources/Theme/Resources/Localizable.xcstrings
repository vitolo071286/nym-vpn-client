    "modeSelectionInfo.fastDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimenta la máxima velocidad con la conectividad de 2 servidores. Este modo aprovecha AmneziaWG, una versión de WireGuard resistente a la censura, ideal para navegar, transmitir y compartir archivos con rapidez."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bénéficiez d'une vitesse maximale avec le mode VPN (via 2 passerelles). Ce mode repose sur AmneziaWG, une version résistante à la censure du protocole WireGuard. Parfait pour la navigation, le streaming et les téléchargements."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2サーバー接続で最高速度を体験できます。このモードでは、検閲に強いバージョンのWireGuardを使用するAmneziaWGを採用しており、高速ブラウジング、ストリーミング、ファイル共有に最適です。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Experience maximum speed with 2-server connectivity. This mode leverages AmneziaWG, a censorship-resistant version of WireGuard, ideal for fast browsing, streaming, and file sharing."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimente a velocidade máxima com a conectividade de 2 servidores. Esse modo aproveita o AmneziaWG, uma versão resistente à censura do WireGuard, ideal para navegação rápida, streaming e compartilhamento de arquivos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Получите максимальную скорость благодаря подключению к двум серверам. В этом режиме используется AmneziaWG, защищенная от цензуры версия WireGuard, которая идеально подходит для быстрого просмотра страниц, стриминга и обмена файлами."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maksimum hız için 2 sunucu bağlantısıyla deneyimleyin. Bu mod, hızlı gezinme, yayın yapma ve dosya paylaşımı için ideal olan, sansüre dayanıklı WireGuard sürümü AmneziaWG'yi kullanır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відчуйте максимальну швидкість завдяки підключенню до 2 серверів. У цьому режимі використовується AmneziaWG, захищена від цензури версія WireGuard, що ідеально підходить для швидкого перегляду веб-сторінок, потокового передавання даних і обміну файлами."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trải nghiệm tốc độ tối đa với kết nối 2 máy chủ. Chế độ này tận dụng AmneziaWG, phiên bản chống kiểm duyệt của WireGuard, lý tưởng cho việc duyệt web, phát trực tuyến và chia sẻ tệp nhanh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过2台服务器连接，您将体验最快速度。此模式使用 AmneziaWG，即 WireGuard 的防审查版本，是快速浏览、流媒体和文件共享的理想选择。"
          }
        }
      }
    },
