        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao continuar, você concorda com os [Termos de uso] da NymVPN (https://nym.com/vpn-terms) e reconhece a [Política de privacidade] da NymVPN (https://nym.com/vpn-privacy-statement)."
